#!/usr/bin/env bash
# =============================================================================
# up — Full system update script
# Runs: apt update/upgrade, Flatpak update, Nix profile upgrade
# =============================================================================
set -euo pipefail

BOLD='\033[1m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
YELLOW='\033[1;33m'; RED='\033[0;31m'; RESET='\033[0m'

step()    { echo -e "\n${BOLD}${CYAN}━━━ $* ━━━${RESET}"; }
success() { echo -e "${GREEN}✓${RESET} $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET}  $*"; }
error()   { echo -e "${RED}✗${RESET}  $*" >&2; }

echo -e "${BOLD}${CYAN}"
echo "  ╔══════════════════════════════════╗"
echo "  ║   🔄  System Update — $(date '+%Y-%m-%d')  ║"
echo "  ╚══════════════════════════════════╝"
echo -e "${RESET}"

# ─── 1. APT ───────────────────────────────────────────────────────────────────
step "APT: update & upgrade"
if command -v apt-get &>/dev/null; then
  sudo apt-get update -qq && \
  sudo apt-get upgrade -y && \
  sudo apt-get autoremove -y --purge && \
  sudo apt-get autoclean -q
  success "APT packages upgraded."
else
  warn "apt-get not found — skipping."
fi

# ─── 2. Flatpak ───────────────────────────────────────────────────────────────
step "Flatpak: update all apps"
if command -v flatpak &>/dev/null; then
  flatpak update -y
  success "Flatpak apps updated."
else
  warn "flatpak not found — skipping."
fi

# ─── 3. Nix ───────────────────────────────────────────────────────────────────
step "Nix: upgrade all profile packages"
if command -v nix &>/dev/null; then
  nix profile upgrade '.*'
  # Clean up unreferenced store paths
  nix store gc
  success "Nix profile upgraded and store cleaned."
else
  warn "nix not found — skipping."
fi

# ─── 4. Zsh plugins ───────────────────────────────────────────────────────────
step "Zsh plugins: pull latest"
ZSH_PLUGINS="${HOME}/.zsh/plugins"
if [[ -d "${ZSH_PLUGINS}" ]]; then
  for plugin_dir in "${ZSH_PLUGINS}"/*/; do
    [[ -d "${plugin_dir}/.git" ]] || continue
    name="$(basename "${plugin_dir}")"
    printf "  Updating %s... " "${name}"
    git -C "${plugin_dir}" pull --ff-only -q && echo "done" || echo "skipped"
  done
  success "Zsh plugins updated."
else
  warn "Zsh plugins directory not found (${ZSH_PLUGINS}) — skipping."
fi

# ─── Done ─────────────────────────────────────────────────────────────────────
echo -e "\n${BOLD}${GREEN}All done! System is up to date. 🚀${RESET}\n"
