#!/usr/bin/env bash
# =============================================================================
# docs — Browse the dotfiles documentation in the terminal
# Usage:
#   docs              Open interactive documentation browser (all docs)
#   docs <name>       Open a specific doc (e.g. docs tools, docs wezterm)
# =============================================================================
set -euo pipefail

BOLD='\033[1m'; CYAN='\033[0;36m'; RED='\033[0;31m'
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RESET='\033[0m'

# ─── Locate the docs directory ────────────────────────────────────────────────
# This script lives at ~/.dotfiles/scripts/docs (symlinked to ~/.local/bin/docs).
# Resolve the real path of this script, then navigate up two levels to find
# the dotfiles root and from there the docs/ directory.
SCRIPT_REAL="$(realpath "${BASH_SOURCE[0]}")"
DOTFILES_DIR="$(dirname "$(dirname "${SCRIPT_REAL}")")"
DOCS_DIR="${DOTFILES_DIR}/docs"

if [[ ! -d "${DOCS_DIR}" ]]; then
  echo -e "${RED}Error:${RESET} Documentation directory not found: ${DOCS_DIR}" >&2
  exit 1
fi

# ─── Require glow ─────────────────────────────────────────────────────────────
if ! command -v glow &>/dev/null; then
  echo -e "${RED}Error:${RESET} 'glow' is not installed." >&2
  echo -e "Install it with:  ${CYAN}nix profile install nixpkgs#glow${RESET}" >&2
  exit 1
fi

print_available_docs() {
  echo -e "${BOLD}Available docs:${RESET}"
  for f in "${DOCS_DIR}"/*.md; do
    name="$(basename "${f}" .md)"
    echo -e "  ${CYAN}docs ${name}${RESET}"
  done
}

select_with_arrows() {
  local title="$1"; shift
  local options=("$@")
  local selected=0
  local key=""

  [[ ${#options[@]} -gt 0 ]] || return 1

  while true; do
    printf '\033[2J\033[H'
    echo -e "${BOLD}${title}${RESET}"
    echo ""
    for i in "${!options[@]}"; do
      if [[ $i -eq $selected ]]; then
        echo -e "${GREEN}> ${options[$i]}${RESET}"
      else
        echo "  ${options[$i]}"
      fi
    done
    echo ""
    echo -e "${YELLOW}Usa las flechas ↑ ↓ y Enter para elegir.${RESET}"

    IFS= read -rsn1 key || return 1
    if [[ "$key" == $'\x1b' ]]; then
      IFS= read -rsn2 key || true
      case "$key" in
        "[A") selected=$(( (selected - 1 + ${#options[@]}) % ${#options[@]} )) ;;
        "[B") selected=$(( (selected + 1) % ${#options[@]} )) ;;
      esac
    elif [[ -z "$key" ]]; then
      REPLY="${options[$selected]}"
      printf '\033[2J\033[H'
      return 0
    fi
  done
}

render_doc() {
  local target="$1"
  if [[ -n "${WEZTERM_PANE:-}" ]]; then
    # In WezTerm, avoid Glow's interactive buffer and page rendered output.
    glow "${target}" | less -R
  else
    glow -p "${target}"
  fi
}

select_doc_with_fzf() {
  find "${DOCS_DIR}" -maxdepth 1 -type f -name '*.md' -printf '%f\n' | \
    sed 's/\.md$//' | \
    sort | \
    fzf --prompt='Docs > ' --height=40% --layout=reverse --border --cycle
}

# ─── Open specific doc or interactive browser ─────────────────────────────────
if [[ $# -gt 1 ]]; then
  echo -e "${YELLOW}Warning:${RESET} Only the first argument is used. Extra arguments are ignored." >&2
fi

if [[ -n "${1:-}" ]]; then
  # Try <name>.md first, then bare <name>
  TARGET=""
  if [[ -f "${DOCS_DIR}/${1}.md" ]]; then
    TARGET="${DOCS_DIR}/${1}.md"
  elif [[ -f "${DOCS_DIR}/${1}" ]]; then
    TARGET="${DOCS_DIR}/${1}"
  else
    echo -e "${RED}Doc not found:${RESET} ${1}" >&2
    echo ""
    print_available_docs
    exit 1
  fi
  render_doc "${TARGET}"
else
  # Interactive browser — list all docs in the directory
  if [[ -t 0 && -t 1 ]]; then
    mapfile -t doc_names < <(find "${DOCS_DIR}" -maxdepth 1 -type f -name '*.md' -printf '%f\n' | sed 's/\.md$//' | sort)
    doc_names+=("salir")
    select_with_arrows "Documentacion" "${doc_names[@]}"
    choice="$REPLY"
    if [[ "$choice" != "salir" ]]; then
      render_doc "${DOCS_DIR}/${choice}.md"
    fi
  else
    if command -v fzf &>/dev/null; then
      choice="$(select_doc_with_fzf || true)"
      [[ -n "${choice}" ]] && render_doc "${DOCS_DIR}/${choice}.md"
    else
      glow "${DOCS_DIR}"
    fi
  fi
fi
